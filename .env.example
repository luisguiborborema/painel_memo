# Supabase — pegue em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Google Agenda (opcional) — integração via Service Account.
# Só no servidor; NUNCA use prefixo NEXT_PUBLIC nestas.
# 1) Google Cloud > crie um projeto > ative "Google Calendar API"
# 2) Crie uma Service Account e gere uma chave JSON
# 3) No Google Agenda, compartilhe o calendário da MEMO com o e-mail da
#    service account, com permissão "Fazer alterações nos eventos"
# 4) GOOGLE_CALENDAR_ID = o ID do calendário (Configurações do calendário >
#    "ID do calendário", ex: xxxx@group.calendar.google.com)
GOOGLE_CLIENT_EMAIL=minha-sa@meu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=xxxxxxxx@group.calendar.google.com
